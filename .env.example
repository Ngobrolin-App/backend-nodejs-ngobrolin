# ======================================================
# BACKEND ENVIRONMENT VARIABLES EXAMPLE
# ======================================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5434
DB_NAME=ngobrolin_db
DB_USER=postgres
DB_PASSWORD=your_database_password_here

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# CORS Configuration
FRONTEND_URL=*

# Socket.io Configuration
SOCKET_CORS_ORIGIN=*

# Firebase Admin Configuration (For Push Notifications)
# Note: PRIVATE_KEY needs to have newlines represented as \n
FIREBASE_PROJECT_ID=ngobrolin-app
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@ngobrolin-app.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_Private_Key_Here\n-----END PRIVATE KEY-----\n"

# Brevo API Configuration (For Forgot Password Email)
BREVO_API_KEY=your_brevo_api_key_here
EMAIL_SENDER=no-reply@ngobrolin.com
APP_NAME=Ngobrolin App

# URL Frontend for deep-linking (Forgot Password Redirect)
FRONTEND_RESET_URL=ngobrolin://reset-password